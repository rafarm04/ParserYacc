Grammar

    0 $accept: program $end

    1 program: statement_list
    2        | /* empty */

    3 statement_list: statement
    4               | statement_list statement

    5 statement: simple_stmt NEWLINE
    6          | compound_stmt
    7          | NEWLINE
    8          | error NEWLINE

    9 simple_stmt: aug_assignment
   10            | assignment
   11            | expression
   12            | return_stmt
   13            | break_stmt
   14            | continue_stmt
   15            | pass_stmt
   16            | import_stmt
   17            | global_stmt
   18            | assert_stmt
   19            | raise_stmt
   20            | del_stmt

   21 compound_stmt: function_def
   22              | if_stmt
   23              | while_stmt
   24              | for_stmt
   25              | try_stmt

   26 suite: NEWLINE INDENT statement_list DEDENT

   27 function_def: decorator_list DEF IDENTIFIER OPEN_PAREN param_list_opt CLOSE_PAREN COLON suite
   28             | decorator_list DEF IDENTIFIER OPEN_PAREN param_list_opt CLOSE_PAREN MINUS GREATER_THAN dotted_name COLON suite

   29 decorator_list: /* empty */
   30               | decorator_list decorator

   31 decorator: AT_SIGN dotted_name NEWLINE
   32          | AT_SIGN dotted_name OPEN_PAREN arg_list_opt CLOSE_PAREN NEWLINE

   33 dotted_name: IDENTIFIER
   34            | dotted_name DOT IDENTIFIER

   35 param_list_opt: /* empty */
   36               | param_list

   37 param_list: param
   38           | param_list COMMA param

   39 param: IDENTIFIER
   40      | IDENTIFIER COLON dotted_name
   41      | IDENTIFIER EQUAL expression
   42      | IDENTIFIER COLON dotted_name EQUAL expression
   43      | MULTIPLY IDENTIFIER
   44      | POWER IDENTIFIER

   45 import_stmt: IMPORT dotted_name
   46            | IMPORT dotted_name AS IDENTIFIER
   47            | FROM dotted_name IMPORT import_list
   48            | FROM dotted_name IMPORT MULTIPLY

   49 import_list: IDENTIFIER
   50            | IDENTIFIER AS IDENTIFIER
   51            | import_list COMMA IDENTIFIER
   52            | import_list COMMA IDENTIFIER AS IDENTIFIER

   53 if_stmt: IF expression COLON suite elif_list else_opt

   54 elif_list: /* empty */
   55          | elif_list ELIF expression COLON suite

   56 else_opt: /* empty */
   57         | ELSE COLON suite

   58 while_stmt: WHILE expression COLON suite else_opt

   59 for_stmt: FOR target IN expression COLON suite else_opt

   60 try_stmt: TRY COLON suite except_list else_opt

   61 except_list: except_clause
   62            | except_list except_clause

   63 except_clause: EXCEPT COLON suite
   64              | EXCEPT expression COLON suite
   65              | EXCEPT expression AS IDENTIFIER COLON suite

   66 assignment: target EQUAL expression
   67           | target COLON dotted_name EQUAL expression
   68           | target COLON dotted_name

   69 aug_assignment: target aug_op expression

   70 aug_op: PLUS_EQ
   71       | MINUS_EQ
   72       | MULTIPLY_EQ
   73       | DIVIDE_EQ
   74       | MODULO_EQ
   75       | POWER_EQ
   76       | FLOOR_DIV_EQ

   77 target: IDENTIFIER
   78       | atom_expr DOT IDENTIFIER
   79       | atom_expr OPEN_BRACKET expression CLOSE_BRACKET

   80 return_stmt: RETURN
   81            | RETURN expression

   82 break_stmt: BREAK

   83 continue_stmt: CONTINUE

   84 pass_stmt: PASS

   85 global_stmt: GLOBAL identifier_list

   86 identifier_list: IDENTIFIER
   87                | identifier_list COMMA IDENTIFIER

   88 assert_stmt: ASSERT expression
   89            | ASSERT expression COMMA expression

   90 raise_stmt: RAISE
   91           | RAISE expression

   92 del_stmt: DEL target

   93 expression: expression OR expression
   94           | expression AND expression
   95           | NOT expression
   96           | expression LESS_THAN expression
   97           | expression GREATER_THAN expression
   98           | expression DOUBLE_EQUAL expression
   99           | expression NOT_EQUAL expression
  100           | expression LESS_EQUAL expression
  101           | expression GREATER_EQUAL expression
  102           | expression IS expression
  103           | expression IN expression
  104           | expression BIT_OR expression
  105           | expression BIT_XOR expression
  106           | expression BIT_AND expression
  107           | expression LEFT_SHIFT expression
  108           | expression RIGHT_SHIFT expression
  109           | expression PLUS expression
  110           | expression MINUS expression
  111           | expression MULTIPLY expression
  112           | expression DIVIDE expression
  113           | expression FLOOR_DIV expression
  114           | expression MODULO expression
  115           | expression POWER expression
  116           | MINUS expression
  117           | PLUS expression
  118           | BIT_NOT expression
  119           | atom_expr

  120 atom_expr: atom
  121          | atom_expr OPEN_PAREN arg_list_opt CLOSE_PAREN
  122          | atom_expr OPEN_BRACKET expression CLOSE_BRACKET
  123          | atom_expr DOT IDENTIFIER

  124 atom: IDENTIFIER
  125     | INT
  126     | FLOAT
  127     | SCIENTIFIC
  128     | STRING
  129     | TRUE
  130     | FALSE
  131     | NONE
  132     | OPEN_PAREN expression CLOSE_PAREN
  133     | OPEN_PAREN tuple_items CLOSE_PAREN
  134     | OPEN_BRACKET expr_list_opt CLOSE_BRACKET
  135     | OPEN_BRACE dict_items_opt CLOSE_BRACE

  136 tuple_items: expression COMMA
  137            | expression COMMA expression
  138            | tuple_items COMMA expression

  139 arg_list_opt: /* empty */
  140             | arg_list

  141 arg_list: arg
  142         | arg_list COMMA arg

  143 arg: expression
  144    | IDENTIFIER EQUAL expression
  145    | MULTIPLY expression
  146    | POWER expression

  147 expr_list_opt: /* empty */
  148              | expr_list

  149 expr_list: expression
  150          | expr_list COMMA expression
  151          | expr_list COMMA

  152 dict_items_opt: /* empty */
  153               | dict_items

  154 dict_items: expression COLON expression
  155           | dict_items COMMA expression COLON expression


